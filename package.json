{
  "name": "phantum",
  "version": "1.0.0",
  "description": "A dashboard to manage Claude Code, Codex, and other terminals on one screen. Click chats to open them as live terminal panes; layout and config persist across restarts.",
  "type": "commonjs",
  "main": "server.js",
  "bin": {
    "phantum": "server.js"
  },
  "scripts": {
    "start": "node server.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "terminal",
    "pty",
    "dashboard",
    "windows",
    "multiplexer"
  ],
  "author": "ultrafro",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^4.22.2",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0"
  }
}
